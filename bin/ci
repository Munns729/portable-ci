#!/usr/bin/env bash
# portable-ci — run your project's CI checks from one config, locally and in CI.
#
# The same `.localci` config drives your local runs and your GitHub Actions run,
# so the two can never drift. Because it runs locally it can also do things a
# server runner can't: install a pre-push git hook, scope checks to changed
# files, and publish a commit status that Claude Code's CI indicator reflects.
#
# Quick start:
#   ci init      # scaffold a .localci for this project (auto-detects your tools)
#   ci run       # run every check in .localci; non-zero exit if any fails
#
# Usage:
#   ci [run] [--config PATH] [--since REF] [--publish-status] [--context NAME] [--repo OWNER/REPO]
#   ci init [--config PATH]
#   ci doctor [--config PATH]
#   ci install-hook [pre-push|pre-commit]
#   ci status [--repo OWNER/REPO]      # what CI does GitHub actually have recorded for HEAD?
#   ci quota [--repo OWNER/REPO]       # remaining GitHub Actions minutes for the repo owner
#   ci resolve-repo [--repo OWNER/REPO]
#   ci resolve-context [--context NAME]
#   ci --version | --help
#
# Env: PORTABLE_CI_REPO=owner/repo sets the repo for --publish-status when the
# git remote is not a github.com URL (proxied checkouts, GitHub Enterprise, forks).
#
# Provenance: a local `--publish-status` run publishes under context
# `portable-ci/local` and a description marked "local backup", so a recorded
# backup can never be mistaken for a hosted GitHub Actions run (context
# `portable-ci`). `ci status` reads back HEAD's checks and labels each one.
#
# Config format (.localci) — a shell fragment that calls `step`:
#   step "lint"  ruff check src/
#   step "types" mypy
#   step "test"  pytest -q
# Each `step` runs a command; any non-zero exit fails the run. For compound
# commands, wrap in a shell: step "build" bash -c "make && make test".
# `step_soft "name" cmd...` is advisory: reported, but never fails the run or a
# published status (e.g. an LLM adversarial review). Every run ends with a
# SHA-stamped attestation line recording what was verified.
set -uo pipefail

# Bump this on every release that changes behaviour. It is the ONLY signal a
# consumer has that their install is behind — `install.sh` installs once from the
# moving `v1` tag and nothing re-checks afterwards.
#
# It has silently failed at that job before: 0.1.0 stayed pinned across seven
# feature PRs (advisory steps, install trust, quota preflight, doctor
# interpreter warning, `ci quota`), so an install predating them reported the
# same version as one containing them. A consumer repo hit exactly this on
# 2026-07-20 — wrote a `step_soft` config, and the installed `ci` errored
# `step_soft: command not found` while `ci --version` claimed parity with HEAD.
VERSION="0.2.0"

# ---------- presentation ----------
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_BOLD=$'\033[1m'; C_GREEN=$'\033[32m'; C_RED=$'\033[31m'; C_DIM=$'\033[2m'; C_RESET=$'\033[0m'
else
  C_BOLD=""; C_GREEN=""; C_RED=""; C_DIM=""; C_RESET=""
fi

# ---------- state ----------
MODE="run"
CONFIG="${PORTABLE_CI_CONFIG:-.localci}"
CONFIG_EXPLICIT=0; [ -n "${PORTABLE_CI_CONFIG:-}" ] && CONFIG_EXPLICIT=1
SINCE=""
PUBLISH_STATUS=0
STATUS_CONTEXT="${PORTABLE_CI_CONTEXT:-}"   # empty => choose default by provenance (see effective_context)
REPO="${PORTABLE_CI_REPO:-}"   # owner/repo override for status publishing
FAIL=0
MISSING=0
ADVISORY_FAIL=0        # advisory steps that failed — reported, but never gate the run
declare -a RESULTS=()   # "ok|name" / "fail|name" / "soft-ok|name" / "soft-fail|name"

usage() {
  # Print the leading comment block (from line 2 until the first non-comment line).
  awk 'NR>1 && /^#/ {sub(/^# ?/,""); print; next} NR>1 {exit}' "$0"
}

# ---------- step implementations ----------
# `step NAME COMMAND...`      — a hard check; failure fails the run.
# `step_soft NAME COMMAND...` — an advisory check; failure is reported but never
#   gates the run or flips the published status to failure. Use it for
#   non-deterministic or informational checks (e.g. an LLM adversarial review)
#   that shouldn't block a merge.
step()      { _dispatch 0 "$@"; }
# shellcheck disable=SC2317  # invoked from sourced .localci configs, not directly here
step_soft() { _dispatch 1 "$@"; }

_dispatch() {
  local advisory="$1"; shift
  case "$MODE" in
    run)    _step_run "$advisory" "$@" ;;
    doctor) _step_doctor "$advisory" "$@" ;;
  esac
}

_step_run() {
  local advisory="$1" name="$2"; shift 2
  local tag=""; [ "$advisory" = "1" ] && tag=" $C_DIM(advisory)$C_RESET"
  printf '%s▶ %s%s%s\n' "$C_BOLD" "$name" "$C_RESET" "$tag"
  local start="$SECONDS"
  if "$@"; then
    local dur=$((SECONDS - start))
    printf '%s✓ %s%s %s(%ss)%s\n\n' "$C_GREEN" "$name" "$C_RESET" "$C_DIM" "$dur" "$C_RESET"
    RESULTS+=("$([ "$advisory" = "1" ] && echo soft-ok || echo ok)|$name")
    _summary_row "$name" "pass" "$dur"
  else
    local rc=$? ; local dur=$((SECONDS - start))
    if [ "$advisory" = "1" ]; then
      # Advisory: surface it clearly, but do NOT set FAIL or touch the exit code.
      printf '%s⚠ %s — advisory (exit %s, %ss), not blocking%s\n\n' "$C_DIM" "$name" "$rc" "$dur" "$C_RESET"
      RESULTS+=("soft-fail|$name")
      ADVISORY_FAIL=$((ADVISORY_FAIL + 1))
      _summary_row "$name" "advisory finding (exit $rc)" "$dur"
    else
      printf '%s✗ %s (exit %s, %ss)%s\n\n' "$C_RED" "$name" "$rc" "$dur" "$C_RESET"
      RESULTS+=("fail|$name")
      FAIL=1
      _summary_row "$name" "FAIL (exit $rc)" "$dur"
    fi
  fi
}

# Tools that must import your project's dependencies to work (type-checkers,
# test runners, coverage). For these, the interpreter their launcher runs under
# has to be the one your deps are installed in — see _interpreter_note.
_INTERP_SENSITIVE=" mypy pytest pyright coverage tox nox pylint "

# Warn when a resolved tool's launcher runs under a different Python than the
# `python3` on PATH. That's the "bare mypy vs python -m mypy" split: the console
# script uses the interpreter baked into its shebang, which may not be the one
# your project's dependencies live in — so it fails cryptically at run time, not
# here. Only checked for interpreter-sensitive tools, and only a hint (never
# fails doctor).
_interpreter_note() {
  case "$_INTERP_SENSITIVE" in *" $1 "*) ;; *) return 0 ;; esac
  local toolpath shebang shpy pathpy a b
  toolpath="$(command -v "$1" 2>/dev/null)" || return 0
  shebang="$(head -c 256 "$toolpath" 2>/dev/null | head -n1)"
  case "$shebang" in \#!*python*) ;; *) return 0 ;; esac
  shpy="${shebang#\#!}"; shpy="${shpy%% *}"           # first token after #!
  case "$shpy" in */env) return 0 ;; esac             # `env python` follows PATH — no split
  pathpy="$(command -v python3 2>/dev/null || command -v python 2>/dev/null || true)"
  [ -n "$pathpy" ] || return 0
  a="$(readlink -f "$shpy" 2>/dev/null || printf '%s' "$shpy")"
  b="$(readlink -f "$pathpy" 2>/dev/null || printf '%s' "$pathpy")"
  [ "$a" = "$b" ] && return 0
  # shellcheck disable=SC2016  # backticks are literal hint text, not substitution
  printf '    %s↳ runs under %s, but your python3 is %s — if deps live in the latter, use `python -m %s`%s\n' \
    "$C_DIM" "$shpy" "$pathpy" "$1" "$C_RESET"
}

# Doctor: check that each step's underlying executable is installed. A missing
# tool for an advisory step is reported as optional and does not fail doctor.
_step_doctor() {
  local advisory="$1" name="$2"; shift 2
  local tool="${1:-}"
  # Unwrap `bash -c` / `sh -c` wrappers to probe the real first word.
  if { [ "$tool" = "bash" ] || [ "$tool" = "sh" ]; } && [ "${2:-}" = "-c" ]; then
    tool="$(printf '%s\n' "$3" | awk '{print $1}')"
  fi
  if command -v "$tool" >/dev/null 2>&1; then
    local ver; ver="$("$tool" --version 2>/dev/null | head -1)"
    printf '  %s✓%s %-16s %s%s%s\n' "$C_GREEN" "$C_RESET" "$name" "$C_DIM" "${ver:-$tool present}" "$C_RESET"
    _interpreter_note "$tool"
  elif [ "$advisory" = "1" ]; then
    printf '  %s○%s %-16s %soptional, missing: %s%s\n' "$C_DIM" "$C_RESET" "$name" "$C_DIM" "$tool" "$C_RESET"
  else
    printf '  %s✗%s %-16s %smissing: %s%s\n' "$C_RED" "$C_RESET" "$name" "$C_DIM" "$tool" "$C_RESET"
    MISSING=$((MISSING + 1))
  fi
}

_summary_row() {
  [ -n "${GITHUB_STEP_SUMMARY:-}" ] || return 0
  printf '| %s | %s | %ss |\n' "$1" "$2" "$3" >> "$GITHUB_STEP_SUMMARY"
}

# ---------- auto-detection (used when no .localci is present) ----------
autodetect() {
  if [ -f pyproject.toml ] || [ -f setup.py ] || ls ./*.py >/dev/null 2>&1; then
    command -v ruff   >/dev/null 2>&1 && step "ruff"   ruff check .
    command -v mypy   >/dev/null 2>&1 && step "mypy"   mypy .
    command -v pytest >/dev/null 2>&1 && step "pytest" pytest -q
  fi
  if [ -f package.json ] && command -v npm >/dev/null 2>&1; then
    local s
    for s in lint typecheck test; do
      if node -e "process.exit((require('./package.json').scripts||{})['$s']?0:1)" 2>/dev/null; then
        step "npm $s" npm run "$s" --silent
      fi
    done
  fi
  if [ "${#RESULTS[@]}" -eq 0 ] && [ "$MISSING" -eq 0 ] && [ "$MODE" = "run" ]; then
    printf '%sportable-ci:%s no %s file and nothing auto-detected.\n' "$C_BOLD" "$C_RESET" "$CONFIG" >&2
    # shellcheck disable=SC2016  # backticks are literal hint text, not substitution
    printf 'Run `ci init` to scaffold one, or add a %s file by hand (see `ci --help`).\n' "$CONFIG" >&2
    exit 2
  fi
}

load_steps() {
  if [ -f "$CONFIG" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG"
  elif [ "$CONFIG_EXPLICIT" = "1" ]; then
    # An explicit --config / PORTABLE_CI_CONFIG that doesn't exist is an error,
    # never a silent fall-through to autodetect — otherwise a typo'd path runs a
    # different set of checks than the caller asked for (and can read as a pass).
    printf '%sportable-ci:%s config file not found: %s\n' "$C_BOLD" "$C_RESET" "$CONFIG" >&2
    exit 2
  else
    autodetect
  fi
}

# ---------- changed-files scoping ----------
compute_changed_files() {
  [ -n "$SINCE" ] || return 0
  if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "portable-ci: --since given but not in a git repo" >&2; return 0
  fi
  CI_CHANGED_FILES="$(git diff --name-only "$SINCE" -- 2>/dev/null)"
  export CI_CHANGED_FILES
  local n; n="$(printf '%s' "$CI_CHANGED_FILES" | grep -c . || true)"
  # shellcheck disable=SC2016  # $CI_CHANGED_FILES is printed literally, on purpose.
  printf '%s%s file(s) changed since %s — exported as $CI_CHANGED_FILES%s\n\n' \
    "$C_DIM" "$n" "$SINCE" "$C_RESET"
}

# ---------- repo resolution ----------
# Echo "owner/repo" for status publishing, or nothing if it can't be determined.
# Honours $REPO (PORTABLE_CI_REPO / --repo) first, then parses a github.com remote.
# Non-github.com remotes (proxied checkouts, GHE) can't be parsed generically —
# that's what the override is for.
resolve_repo() {
  if [ -n "$REPO" ]; then printf '%s\n' "$REPO"; return 0; fi
  local remote
  remote="$(git config --get remote.origin.url 2>/dev/null || true)"
  [ -n "$remote" ] || return 0
  printf '%s' "$remote" \
    | sed -E 's#^(git@github.com:|https://github.com/|ssh://git@github.com/)##; s#\.git$##' \
    | grep -E '^[^/]+/[^/]+$' || true
}

# ---------- provenance helpers ----------
# True inside a GitHub Actions job — a run there is "hosted", not a local backup.
in_github_actions() { [ "${GITHUB_ACTIONS:-}" = "true" ]; }

# The commit-status context to publish under. An explicit --context /
# PORTABLE_CI_CONTEXT always wins. Otherwise default so a local backup can never
# wear the same name as a hosted run: `portable-ci` in Actions, `portable-ci/local`
# when run from a developer's machine.
effective_context() {
  if [ -n "$STATUS_CONTEXT" ]; then printf '%s\n' "$STATUS_CONTEXT"; return 0; fi
  if in_github_actions; then printf 'portable-ci\n'; else printf 'portable-ci/local\n'; fi
}

# A description that can't overstate the run: says whether it was hosted or a
# local backup, how many checks ran, and whether it was scoped to changed files
# (i.e. partial). GitHub truncates statuses at 140 chars; this stays well under.
status_description() {
  local passed=0 failed=0 soft_fail=0 r
  for r in "${RESULTS[@]:-}"; do
    [ -n "$r" ] || continue
    case "${r%%|*}" in
      ok)        passed=$((passed + 1)) ;;
      fail)      failed=$((failed + 1)) ;;
      soft-ok)   passed=$((passed + 1)) ;;
      soft-fail) soft_fail=$((soft_fail + 1)) ;;
    esac
  done
  local total=$((passed + failed)) origin desc
  if in_github_actions; then origin="hosted"; else origin="local backup"; fi
  if [ "$failed" -gt 0 ]; then
    desc="$origin · $passed/$total passed, $failed failed"
  else
    desc="$origin · $total/$total checks passed"
  fi
  # Advisory findings update the description but never the pass/fail state.
  [ "$soft_fail" -gt 0 ] && desc="$desc · $soft_fail advisory finding(s)"
  [ -n "$SINCE" ] && desc="$desc · scoped to $SINCE (partial)"
  printf '%s' "$desc"
}

# A SHA-stamped, copy-pasteable record of what this run actually verified —
# the basis you can paste to attest "these checks passed on this exact commit".
# Deterministic and network-free (no timestamp/host): the SHA is the stamp.
attestation() {
  local sha; sha="$(git rev-parse --verify --short=12 HEAD 2>/dev/null || true)"
  local hp=0 hf=0 sf=0 r
  for r in "${RESULTS[@]:-}"; do
    [ -n "$r" ] || continue
    case "${r%%|*}" in
      ok)        hp=$((hp + 1)) ;;
      fail)      hf=$((hf + 1)) ;;
      soft-fail) sf=$((sf + 1)) ;;
    esac
  done
  local total=$((hp + hf)) verdict="passed"
  [ "$FAIL" -ne 0 ] && verdict="FAILED"
  local line="portable-ci attestation: $verdict"
  [ -n "$sha" ] && line="$line @ $sha"
  line="$line · $hp/$total checks"
  [ "$sf" -gt 0 ] && line="$line · $sf advisory finding(s)"
  [ -n "$SINCE" ] && line="$line · scoped to $SINCE"
  printf '%s%s%s\n' "$C_DIM" "$line" "$C_RESET"
}

# Minimal JSON string escaping (backslash and double-quote) so descriptions and
# refs with odd characters can't break the payload. Keeps the publish path
# dependency-free (no jq needed just to POST a status).
_json_escape() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

# Resolve a GitHub token from the usual places (env, then gh CLI). Echoes empty
# if none is available.
_resolve_token() {
  local t="${GITHUB_TOKEN:-${GH_TOKEN:-}}"
  if [ -z "$t" ] && command -v gh >/dev/null 2>&1; then t="$(gh auth token 2>/dev/null || true)"; fi
  printf '%s' "$t"
}

# ---------- GitHub commit status (Claude Code CI-indicator integration) ----------
publish_status() {
  local state="success"; [ "$FAIL" -ne 0 ] && state="failure"
  local token; token="$(_resolve_token)"
  if [ -z "$token" ]; then
    echo "portable-ci: no GITHUB_TOKEN/GH_TOKEN and no gh auth — skipping status publish" >&2
    return 0
  fi
  local owner_repo owner repo sha
  owner_repo="$(resolve_repo)"
  if [ -z "$owner_repo" ]; then
    echo "portable-ci: could not determine owner/repo from the git remote — set PORTABLE_CI_REPO=owner/repo (or --repo owner/repo)" >&2
    return 0
  fi
  owner="${owner_repo%%/*}"; repo="${owner_repo#*/}"
  sha="$(git rev-parse HEAD)"

  local ctx desc url payload
  ctx="$(effective_context)"
  desc="$(status_description)"
  url=""
  if in_github_actions && [ -n "${GITHUB_SERVER_URL:-}" ] && [ -n "${GITHUB_RUN_ID:-}" ]; then
    url="$GITHUB_SERVER_URL/$owner/$repo/actions/runs/$GITHUB_RUN_ID"
  fi
  payload="{\"state\":\"$state\",\"context\":\"$(_json_escape "$ctx")\",\"description\":\"$(_json_escape "$desc")\""
  [ -n "$url" ] && payload="$payload,\"target_url\":\"$(_json_escape "$url")\""
  payload="$payload}"

  local code
  code="$(curl -sS -o /dev/null -w '%{http_code}' -X POST \
    -H "Authorization: Bearer $token" \
    -H "Accept: application/vnd.github+json" \
    "https://api.github.com/repos/$owner/$repo/statuses/$sha" \
    -d "$payload" 2>/dev/null)"
  if [ "$code" = "201" ]; then
    printf 'portable-ci: published %s status (%s) for %s — %s\n' "$state" "$ctx" "${sha:0:12}" "$desc"
  else
    printf 'portable-ci: status publish failed (HTTP %s) — need a token with "repo:status" scope\n' "$code" >&2
  fi
}

# ---------- read back what GitHub actually has (`ci status`) ----------
# Answers "is the green light real hosted CI, or a local portable-ci backup?"
# for HEAD, by listing both check runs (Actions/apps = hosted) and commit
# statuses (where our backups live) and labelling each one.
status_report() {
  if ! command -v jq >/dev/null 2>&1; then
    echo "portable-ci: \`ci status\` needs jq to parse GitHub's API — install jq and retry." >&2
    return 2
  fi
  local token; token="$(_resolve_token)"
  if [ -z "$token" ]; then
    echo "portable-ci: no GITHUB_TOKEN/GH_TOKEN and no gh auth — can't read GitHub status" >&2
    return 1
  fi
  local owner_repo owner repo sha
  owner_repo="$(resolve_repo)"
  if [ -z "$owner_repo" ]; then
    echo "portable-ci: could not determine owner/repo — set PORTABLE_CI_REPO=owner/repo (or --repo owner/repo)" >&2
    return 1
  fi
  owner="${owner_repo%%/*}"; repo="${owner_repo#*/}"
  sha="$(git rev-parse --verify HEAD 2>/dev/null)"
  if [ -z "$sha" ]; then echo "portable-ci: not a git repo / no commit at HEAD" >&2; return 1; fi

  local api="https://api.github.com/repos/$owner/$repo/commits/$sha"
  local checks statuses
  checks="$(curl -sS -H "Authorization: Bearer $token" -H "Accept: application/vnd.github+json" "$api/check-runs" 2>/dev/null)"
  statuses="$(curl -sS -H "Authorization: Bearer $token" -H "Accept: application/vnd.github+json" "$api/status" 2>/dev/null)"

  printf '%sportable-ci status%s for %s %s(%s)%s\n\n' \
    "$C_BOLD" "$C_RESET" "${sha:0:12}" "$C_DIM" "$owner/$repo" "$C_RESET"

  local hosted_n=0 backup_n=0 other_n=0 origin name state detail glyph
  # Check runs are always hosted (GitHub Actions or a GitHub App).
  while IFS=$'\t' read -r name state _; do
    [ -n "$name" ] || continue
    hosted_n=$((hosted_n + 1))
    glyph="$(_state_glyph "$state")"
    printf '  %s  %-22s %shosted (Actions/app)%s  %s\n' "$glyph" "$name" "$C_DIM" "$C_RESET" "$state"
  done < <(printf '%s' "$checks" | jq -r '.check_runs[]? | [.name, (.conclusion // .status // "pending")] | @tsv')

  # Commit statuses: this is where a portable-ci backup lands. Classify each.
  while IFS=$'\t' read -r name state detail; do
    [ -n "$name" ] || continue
    case "$name" in
      */local) origin="local backup" ;;
      *) case "$detail" in "local backup"*) origin="local backup" ;; *) origin="commit status" ;; esac ;;
    esac
    if [ "$origin" = "local backup" ]; then backup_n=$((backup_n + 1)); else other_n=$((other_n + 1)); fi
    glyph="$(_state_glyph "$state")"
    printf '  %s  %-22s %s%-19s%s  %s\n' "$glyph" "$name" "$C_DIM" "$origin" "$C_RESET" "${detail:-$state}"
  done < <(printf '%s' "$statuses" | jq -r '.statuses[]? | [.context, .state, (.description // "")] | @tsv')

  if [ $((hosted_n + backup_n + other_n)) -eq 0 ]; then
    printf '  %sno checks or statuses recorded for this commit.%s\n' "$C_DIM" "$C_RESET"
    return 0
  fi

  printf '\n%ssummary:%s %s hosted, %s local backup, %s other\n' \
    "$C_BOLD" "$C_RESET" "$hosted_n" "$backup_n" "$other_n"
  # The whole point: warn when nothing but a local backup vouches for this commit.
  if [ "$hosted_n" -eq 0 ] && [ "$other_n" -eq 0 ] && [ "$backup_n" -gt 0 ]; then
    printf '%s⚠ hosted CI has not verified this commit — the only checks here are local portable-ci backups.%s\n' \
      "$C_RED" "$C_RESET"
  fi
}

# Map a GitHub state/conclusion to a ✓/✗/• glyph.
_state_glyph() {
  case "$1" in
    success) printf '%s✓%s' "$C_GREEN" "$C_RESET" ;;
    failure|error|cancelled|timed_out) printf '%s✗%s' "$C_RED" "$C_RESET" ;;
    *) printf '%s•%s' "$C_DIM" "$C_RESET" ;;
  esac
}

# Pull an integer value for a top-level JSON key out of a flat response body,
# without a jq dependency (the billing response is a small, well-known shape:
# a handful of top-level int fields — no nesting worth a real parser for).
_json_num() {
  printf '%s' "$2" | grep -o "\"$1\"[[:space:]]*:[[:space:]]*[0-9][0-9]*" | head -1 | grep -o '[0-9]*$'
}

# ---------- Actions quota preflight (`ci quota`) ----------
# On a private repo, exhausted Actions minutes don't fail loudly — a job never
# schedules and GitHub still records a red "failure" in ~0s (see the `ci status`
# hosted-vs-backup split for the flip side of this same problem). Checking
# quota BEFORE relying on a hosted result avoids chasing a false failure. Exit
# codes mirror `step`/`status`: 0 = quota available, 1 = exhausted (compose it:
# `ci quota || use the local ci run verdict`), 2 = couldn't determine.
quota_report() {
  local token; token="$(_resolve_token)"
  if [ -z "$token" ]; then
    echo "portable-ci: no GITHUB_TOKEN/GH_TOKEN and no gh auth — can't check Actions quota (needs a token that can read billing: a classic PAT, or a fine-grained token with Plan: read)" >&2
    return 2
  fi
  local owner_repo owner
  owner_repo="$(resolve_repo)"
  if [ -z "$owner_repo" ]; then
    echo "portable-ci: could not determine owner/repo — set PORTABLE_CI_REPO=owner/repo (or --repo owner/repo)" >&2
    return 2
  fi
  owner="${owner_repo%%/*}"

  # The billing endpoint differs for a personal account vs an organization;
  # `owner` could be either, so try user first and fall back to org.
  local resp code body
  resp="$(curl -sS -w '\n%{http_code}' -H "Authorization: Bearer $token" -H "Accept: application/vnd.github+json" \
    "https://api.github.com/users/$owner/settings/billing/actions" 2>/dev/null)"
  code="${resp##*$'\n'}"; body="${resp%$'\n'*}"
  if [ "$code" != "200" ]; then
    resp="$(curl -sS -w '\n%{http_code}' -H "Authorization: Bearer $token" -H "Accept: application/vnd.github+json" \
      "https://api.github.com/orgs/$owner/settings/billing/actions" 2>/dev/null)"
    code="${resp##*$'\n'}"; body="${resp%$'\n'*}"
  fi
  if [ "$code" != "200" ]; then
    printf 'portable-ci: could not read Actions billing for %s (HTTP %s) — needs a token that can read billing (classic PAT, or a fine-grained token with Plan: read)\n' "$owner" "$code" >&2
    return 2
  fi

  local included used remaining
  included="$(_json_num included_minutes "$body")"
  used="$(_json_num total_minutes_used "$body")"
  if [ -z "$included" ] || [ -z "$used" ]; then
    echo "portable-ci: unexpected billing response shape for $owner" >&2
    return 2
  fi
  remaining=$((included - used))
  printf '%sportable-ci quota%s: %s/%s Actions minutes used for %s — %s remaining\n' \
    "$C_BOLD" "$C_RESET" "$used" "$included" "$owner" "$remaining"
  if [ "$remaining" -le 0 ]; then
    # shellcheck disable=SC2016  # backticks are literal hint text, not substitution
    printf '%s⚠ no Actions minutes left — hosted CI will not schedule; rely on `ci run` / `ci status` instead.%s\n' \
      "$C_RED" "$C_RESET"
    return 1
  fi
}

# ---------- config scaffolder (`ci init`) ----------
# Detect the project's toolchain and write a ready-to-run .localci, so users
# never have to hand-write the config or read the format docs first.
init_config() {
  local target="$CONFIG"
  if [ -e "$target" ]; then
    echo "portable-ci: $target already exists; leaving it alone. Edit it directly, or remove it and re-run \`ci init\`." >&2
    exit 1
  fi

  local -a detected=()
  local kind="generic"
  if [ -f pyproject.toml ] || [ -f setup.py ] || ls ./*.py >/dev/null 2>&1; then
    kind="python"
    command -v ruff   >/dev/null 2>&1 && detected+=('step "lint"  ruff check .')
    command -v mypy   >/dev/null 2>&1 && detected+=('step "types" mypy .')
    command -v pytest >/dev/null 2>&1 && detected+=('step "test"  pytest -q')
  fi
  if [ -f package.json ]; then
    kind="node"
    local s
    for s in lint typecheck test; do
      if node -e "process.exit((require('./package.json').scripts||{})['$s']?0:1)" 2>/dev/null; then
        detected+=("step \"$s\"  npm run $s --silent")
      fi
    done
  fi

  # Backticks below are literal help text in the generated file, not command
  # substitution — printf prints them verbatim.
  # shellcheck disable=SC2016
  {
    printf '# portable-ci config — each `step "name" command...` runs one check.\n'
    printf '# Any non-zero exit fails the run. Compound commands: step "build" bash -c "make && make test".\n'
    printf '# Regenerate examples any time with `ci init` (into a fresh file). Docs: run `ci --help`.\n\n'
    if [ "${#detected[@]}" -gt 0 ]; then
      printf '# Detected a %s project — these were filled in from tools found on your PATH.\n' "$kind"
      printf '# Edit the commands to match how your project actually runs its checks.\n'
      printf '%s\n' "${detected[@]}"
    else
      printf '# No toolchain auto-detected — uncomment and edit the checks your project needs.\n'
      printf '# step "lint"  ruff check src/\n'
      printf '# step "types" mypy\n'
      printf '# step "test"  pytest -q\n'
    fi
    printf '\n# Changed-files scoping (with `ci run --since origin/main`):\n'
    printf '# step "changed" bash -c '"'"'[ -z "$CI_CHANGED_FILES" ] || ruff check $CI_CHANGED_FILES'"'"'\n'
  } > "$target"

  printf '%sportable-ci:%s wrote %s' "$C_BOLD" "$C_RESET" "$target"
  [ "${#detected[@]}" -gt 0 ] && printf ' with %s detected check(s)' "${#detected[@]}"
  printf '.\n'
  echo "Review it, then run: ci run"
  echo "Tip: \`ci install-hook pre-push\` runs these checks on every push — your"
  echo "     verdict locally, before GitHub Actions is ever in the picture."
}

# ---------- git hook installer ----------
install_hook() {
  local hook="${1:-pre-push}"
  case "$hook" in pre-push|pre-commit) ;; *) echo "portable-ci: hook must be pre-push or pre-commit" >&2; exit 2 ;; esac
  local dir; dir="$(git rev-parse --git-path hooks 2>/dev/null)" || { echo "portable-ci: not a git repo" >&2; exit 2; }
  mkdir -p "$dir"
  local path="$dir/$hook"
  if [ -e "$path" ] && ! grep -q "portable-ci managed hook" "$path" 2>/dev/null; then
    echo "portable-ci: $path already exists and is not managed by portable-ci; leaving it alone." >&2
    exit 1
  fi
  cat > "$path" <<'HOOK'
#!/usr/bin/env bash
# portable-ci managed hook — runs .localci before the git action proceeds, so
# you get your CI verdict locally *before* pushing (and before GitHub Actions).
echo "portable-ci: running .localci before push — your pre-Actions verdict" >&2
exec ci run
HOOK
  chmod +x "$path"
  echo "portable-ci: installed $hook hook at $path"
  echo "portable-ci: .localci now runs on every $hook — you'll see the verdict before Actions does."
}

# ---------- arg parsing ----------
case "${1:-run}" in
  init)            MODE="init"; shift ;;
  doctor)          MODE="doctor"; shift ;;
  status)          MODE="status"; shift ;;
  quota)           MODE="quota"; shift ;;
  install-hook)    shift; install_hook "${1:-pre-push}"; exit 0 ;;
  resolve-repo)    shift; [ "${1:-}" = "--repo" ] && REPO="$2"; resolve_repo; exit 0 ;;
  resolve-context) shift; [ "${1:-}" = "--context" ] && STATUS_CONTEXT="$2"; effective_context; exit 0 ;;
  --version|-V)    echo "portable-ci $VERSION"; exit 0 ;;
  -h|--help)       usage; exit 0 ;;
  run)             shift ;;
esac

while [ $# -gt 0 ]; do
  case "$1" in
    --config)         CONFIG="$2"; CONFIG_EXPLICIT=1; shift 2 ;;
    --since)          SINCE="$2"; shift 2 ;;
    --publish-status) PUBLISH_STATUS=1; shift ;;
    --context)        STATUS_CONTEXT="$2"; shift 2 ;;
    --repo)           REPO="$2"; shift 2 ;;
    -h|--help)        usage; exit 0 ;;
    *) echo "portable-ci: unknown argument: $1" >&2; usage; exit 2 ;;
  esac
done

# ---------- main ----------
if [ "$MODE" = "init" ]; then
  init_config
  exit 0
fi

if [ "$MODE" = "status" ]; then
  status_report
  exit $?
fi

if [ "$MODE" = "quota" ]; then
  quota_report
  exit $?
fi

# ---------- install staleness (`ci doctor`) ----------
# Compare the running VERSION against the latest published release. Advisory and
# entirely optional: no token, no network, or no `gh` simply prints nothing.
# Never fails doctor — being behind is not a broken install.
version_note() {
  command -v gh >/dev/null 2>&1 || return 0
  local latest
  latest="$(gh api repos/Munns729/portable-ci/releases/latest --jq .tag_name 2>/dev/null)" || return 0
  [ -n "$latest" ] || return 0
  local norm="${latest#v}"
  # Only compare against a SEMVER-shaped release tag. `v1` is the MOVING major
  # tag the composite action is pinned to; it can be the "latest release" and
  # normalises to `1`, which would never equal VERSION and would nag on every
  # doctor run forever. Anything not X.Y.Z is not a version claim — skip.
  case "$norm" in
    [0-9]*.[0-9]*.[0-9]*) ;;
    *) return 0 ;;
  esac
  if [ "$norm" != "$VERSION" ]; then
    printf '
%sInstall%s
' "$C_BOLD" "$C_RESET"
    printf '  %s○%s running %s, latest is %s — `curl -fsSL https://raw.githubusercontent.com/Munns729/portable-ci/v1/install.sh | bash`
'       "$C_DIM" "$C_RESET" "$VERSION" "$latest"
  fi
}

if [ "$MODE" = "doctor" ]; then
  printf '%sportable-ci doctor%s — checking configured tools\n\n' "$C_BOLD" "$C_RESET"
  load_steps
  version_note
  echo
  if [ "$MISSING" -gt 0 ]; then
    printf '%s%s tool(s) missing.%s\n' "$C_RED" "$MISSING" "$C_RESET"; exit 1
  fi
  printf '%sall configured tools present.%s\n' "$C_GREEN" "$C_RESET"; exit 0
fi

compute_changed_files
load_steps

echo "── portable-ci summary ──"
for r in "${RESULTS[@]:-}"; do
  [ -n "$r" ] || continue
  name="${r#*|}"
  case "${r%%|*}" in
    ok)        printf '  %s✓%s %s\n' "$C_GREEN" "$C_RESET" "$name" ;;
    fail)      printf '  %s✗%s %s\n' "$C_RED" "$C_RESET" "$name" ;;
    soft-ok)   printf '  %s✓%s %s %s(advisory)%s\n' "$C_GREEN" "$C_RESET" "$name" "$C_DIM" "$C_RESET" ;;
    soft-fail) printf '  %s⚠%s %s %s(advisory — not blocking)%s\n' "$C_DIM" "$C_RESET" "$name" "$C_DIM" "$C_RESET" ;;
  esac
done
[ "$ADVISORY_FAIL" -gt 0 ] && printf '%s%s advisory finding(s) — reported, not gating.%s\n' "$C_DIM" "$ADVISORY_FAIL" "$C_RESET"

[ "$PUBLISH_STATUS" -eq 1 ] && publish_status

if [ "$FAIL" -ne 0 ]; then
  printf '%sportable-ci: FAILED%s\n' "$C_RED" "$C_RESET"
else
  printf '%sportable-ci: passed%s\n' "$C_GREEN" "$C_RESET"
fi
attestation
exit "$FAIL"
