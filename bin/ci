#!/usr/bin/env bash
# portable-ci — run your project's CI checks from one config, locally and in CI.
#
# The same `.localci` config drives your local runs and your GitHub Actions run,
# so the two can never drift. Because it runs locally it can also do things a
# server runner can't: install a pre-push git hook, scope checks to changed
# files, and publish a commit status that Claude Code's CI indicator reflects.
#
# Quick start:
#   ci init      # scaffold a .localci for this project (auto-detects your tools)
#   ci run       # run every check in .localci; non-zero exit if any fails
#
# Usage:
#   ci [run] [--config PATH] [--since REF] [--publish-status] [--context NAME] [--repo OWNER/REPO]
#   ci init [--config PATH]
#   ci doctor [--config PATH]
#   ci install-hook [pre-push|pre-commit]
#   ci resolve-repo [--repo OWNER/REPO]
#   ci --version | --help
#
# Env: PORTABLE_CI_REPO=owner/repo sets the repo for --publish-status when the
# git remote is not a github.com URL (proxied checkouts, GitHub Enterprise, forks).
#
# Config format (.localci) — a shell fragment that calls `step`:
#   step "lint"  ruff check src/
#   step "types" mypy
#   step "test"  pytest -q
# Each `step` runs a command; any non-zero exit fails the run. For compound
# commands, wrap in a shell: step "build" bash -c "make && make test".
set -uo pipefail

VERSION="0.1.0"

# ---------- presentation ----------
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_BOLD=$'\033[1m'; C_GREEN=$'\033[32m'; C_RED=$'\033[31m'; C_DIM=$'\033[2m'; C_RESET=$'\033[0m'
else
  C_BOLD=""; C_GREEN=""; C_RED=""; C_DIM=""; C_RESET=""
fi

# ---------- state ----------
MODE="run"
CONFIG="${PORTABLE_CI_CONFIG:-.localci}"
SINCE=""
PUBLISH_STATUS=0
STATUS_CONTEXT="${PORTABLE_CI_CONTEXT:-portable-ci}"
REPO="${PORTABLE_CI_REPO:-}"   # owner/repo override for status publishing
FAIL=0
MISSING=0
declare -a RESULTS=()   # "ok|name" / "fail|name"

usage() {
  # Print the leading comment block (from line 2 until the first non-comment line).
  awk 'NR>1 && /^#/ {sub(/^# ?/,""); print; next} NR>1 {exit}' "$0"
}

# ---------- step implementations ----------
# `step NAME COMMAND...` — dispatched by MODE.
step() {
  case "$MODE" in
    run)    _step_run "$@" ;;
    doctor) _step_doctor "$@" ;;
  esac
}

_step_run() {
  local name="$1"; shift
  printf '%s▶ %s%s\n' "$C_BOLD" "$name" "$C_RESET"
  local start="$SECONDS"
  if "$@"; then
    local dur=$((SECONDS - start))
    printf '%s✓ %s%s %s(%ss)%s\n\n' "$C_GREEN" "$name" "$C_RESET" "$C_DIM" "$dur" "$C_RESET"
    RESULTS+=("ok|$name")
    _summary_row "$name" "pass" "$dur"
  else
    local rc=$? ; local dur=$((SECONDS - start))
    printf '%s✗ %s (exit %s, %ss)%s\n\n' "$C_RED" "$name" "$rc" "$dur" "$C_RESET"
    RESULTS+=("fail|$name")
    FAIL=1
    _summary_row "$name" "FAIL (exit $rc)" "$dur"
  fi
}

# Doctor: check that each step's underlying executable is installed.
_step_doctor() {
  local name="$1"; shift
  local tool="${1:-}"
  # Unwrap `bash -c` / `sh -c` wrappers to probe the real first word.
  if { [ "$tool" = "bash" ] || [ "$tool" = "sh" ]; } && [ "${2:-}" = "-c" ]; then
    tool="$(printf '%s\n' "$3" | awk '{print $1}')"
  fi
  if command -v "$tool" >/dev/null 2>&1; then
    local ver; ver="$("$tool" --version 2>/dev/null | head -1)"
    printf '  %s✓%s %-16s %s%s%s\n' "$C_GREEN" "$C_RESET" "$name" "$C_DIM" "${ver:-$tool present}" "$C_RESET"
  else
    printf '  %s✗%s %-16s %smissing: %s%s\n' "$C_RED" "$C_RESET" "$name" "$C_DIM" "$tool" "$C_RESET"
    MISSING=$((MISSING + 1))
  fi
}

_summary_row() {
  [ -n "${GITHUB_STEP_SUMMARY:-}" ] || return 0
  printf '| %s | %s | %ss |\n' "$1" "$2" "$3" >> "$GITHUB_STEP_SUMMARY"
}

# ---------- auto-detection (used when no .localci is present) ----------
autodetect() {
  if [ -f pyproject.toml ] || [ -f setup.py ] || ls ./*.py >/dev/null 2>&1; then
    command -v ruff   >/dev/null 2>&1 && step "ruff"   ruff check .
    command -v mypy   >/dev/null 2>&1 && step "mypy"   mypy .
    command -v pytest >/dev/null 2>&1 && step "pytest" pytest -q
  fi
  if [ -f package.json ] && command -v npm >/dev/null 2>&1; then
    local s
    for s in lint typecheck test; do
      if node -e "process.exit((require('./package.json').scripts||{})['$s']?0:1)" 2>/dev/null; then
        step "npm $s" npm run "$s" --silent
      fi
    done
  fi
  if [ "${#RESULTS[@]}" -eq 0 ] && [ "$MISSING" -eq 0 ] && [ "$MODE" = "run" ]; then
    printf '%sportable-ci:%s no %s file and nothing auto-detected.\n' "$C_BOLD" "$C_RESET" "$CONFIG" >&2
    # shellcheck disable=SC2016  # backticks are literal hint text, not substitution
    printf 'Run `ci init` to scaffold one, or add a %s file by hand (see `ci --help`).\n' "$CONFIG" >&2
    exit 2
  fi
}

load_steps() {
  if [ -f "$CONFIG" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG"
  else
    autodetect
  fi
}

# ---------- changed-files scoping ----------
compute_changed_files() {
  [ -n "$SINCE" ] || return 0
  if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "portable-ci: --since given but not in a git repo" >&2; return 0
  fi
  CI_CHANGED_FILES="$(git diff --name-only "$SINCE" -- 2>/dev/null)"
  export CI_CHANGED_FILES
  local n; n="$(printf '%s' "$CI_CHANGED_FILES" | grep -c . || true)"
  # shellcheck disable=SC2016  # $CI_CHANGED_FILES is printed literally, on purpose.
  printf '%s%s file(s) changed since %s — exported as $CI_CHANGED_FILES%s\n\n' \
    "$C_DIM" "$n" "$SINCE" "$C_RESET"
}

# ---------- repo resolution ----------
# Echo "owner/repo" for status publishing, or nothing if it can't be determined.
# Honours $REPO (PORTABLE_CI_REPO / --repo) first, then parses a github.com remote.
# Non-github.com remotes (proxied checkouts, GHE) can't be parsed generically —
# that's what the override is for.
resolve_repo() {
  if [ -n "$REPO" ]; then printf '%s\n' "$REPO"; return 0; fi
  local remote
  remote="$(git config --get remote.origin.url 2>/dev/null || true)"
  [ -n "$remote" ] || return 0
  printf '%s' "$remote" \
    | sed -E 's#^(git@github.com:|https://github.com/|ssh://git@github.com/)##; s#\.git$##' \
    | grep -E '^[^/]+/[^/]+$' || true
}

# ---------- GitHub commit status (Claude Code CI-indicator integration) ----------
publish_status() {
  local state="success"; [ "$FAIL" -ne 0 ] && state="failure"
  local token="${GITHUB_TOKEN:-${GH_TOKEN:-}}"
  if [ -z "$token" ] && command -v gh >/dev/null 2>&1; then
    token="$(gh auth token 2>/dev/null || true)"
  fi
  if [ -z "$token" ]; then
    echo "portable-ci: no GITHUB_TOKEN/GH_TOKEN and no gh auth — skipping status publish" >&2
    return 0
  fi
  local owner_repo owner repo sha
  owner_repo="$(resolve_repo)"
  if [ -z "$owner_repo" ]; then
    echo "portable-ci: could not determine owner/repo from the git remote — set PORTABLE_CI_REPO=owner/repo (or --repo owner/repo)" >&2
    return 0
  fi
  owner="${owner_repo%%/*}"; repo="${owner_repo#*/}"
  sha="$(git rev-parse HEAD)"
  local code
  code="$(curl -sS -o /dev/null -w '%{http_code}' -X POST \
    -H "Authorization: Bearer $token" \
    -H "Accept: application/vnd.github+json" \
    "https://api.github.com/repos/$owner/$repo/statuses/$sha" \
    -d "{\"state\":\"$state\",\"context\":\"$STATUS_CONTEXT\",\"description\":\"portable-ci: $state\"}" 2>/dev/null)"
  if [ "$code" = "201" ]; then
    printf 'portable-ci: published %s status (%s) for %s\n' "$state" "$STATUS_CONTEXT" "${sha:0:12}"
  else
    printf 'portable-ci: status publish failed (HTTP %s) — need a token with "repo:status" scope\n' "$code" >&2
  fi
}

# ---------- config scaffolder (`ci init`) ----------
# Detect the project's toolchain and write a ready-to-run .localci, so users
# never have to hand-write the config or read the format docs first.
init_config() {
  local target="$CONFIG"
  if [ -e "$target" ]; then
    echo "portable-ci: $target already exists; leaving it alone. Edit it directly, or remove it and re-run \`ci init\`." >&2
    exit 1
  fi

  local -a detected=()
  local kind="generic"
  if [ -f pyproject.toml ] || [ -f setup.py ] || ls ./*.py >/dev/null 2>&1; then
    kind="python"
    command -v ruff   >/dev/null 2>&1 && detected+=('step "lint"  ruff check .')
    command -v mypy   >/dev/null 2>&1 && detected+=('step "types" mypy .')
    command -v pytest >/dev/null 2>&1 && detected+=('step "test"  pytest -q')
  fi
  if [ -f package.json ]; then
    kind="node"
    local s
    for s in lint typecheck test; do
      if node -e "process.exit((require('./package.json').scripts||{})['$s']?0:1)" 2>/dev/null; then
        detected+=("step \"$s\"  npm run $s --silent")
      fi
    done
  fi

  # Backticks below are literal help text in the generated file, not command
  # substitution — printf prints them verbatim.
  # shellcheck disable=SC2016
  {
    printf '# portable-ci config — each `step "name" command...` runs one check.\n'
    printf '# Any non-zero exit fails the run. Compound commands: step "build" bash -c "make && make test".\n'
    printf '# Regenerate examples any time with `ci init` (into a fresh file). Docs: run `ci --help`.\n\n'
    if [ "${#detected[@]}" -gt 0 ]; then
      printf '# Detected a %s project — these were filled in from tools found on your PATH.\n' "$kind"
      printf '# Edit the commands to match how your project actually runs its checks.\n'
      printf '%s\n' "${detected[@]}"
    else
      printf '# No toolchain auto-detected — uncomment and edit the checks your project needs.\n'
      printf '# step "lint"  ruff check src/\n'
      printf '# step "types" mypy\n'
      printf '# step "test"  pytest -q\n'
    fi
    printf '\n# Changed-files scoping (with `ci run --since origin/main`):\n'
    printf '# step "changed" bash -c '"'"'[ -z "$CI_CHANGED_FILES" ] || ruff check $CI_CHANGED_FILES'"'"'\n'
  } > "$target"

  printf '%sportable-ci:%s wrote %s' "$C_BOLD" "$C_RESET" "$target"
  [ "${#detected[@]}" -gt 0 ] && printf ' with %s detected check(s)' "${#detected[@]}"
  printf '.\n'
  echo "Review it, then run: ci run"
}

# ---------- git hook installer ----------
install_hook() {
  local hook="${1:-pre-push}"
  case "$hook" in pre-push|pre-commit) ;; *) echo "portable-ci: hook must be pre-push or pre-commit" >&2; exit 2 ;; esac
  local dir; dir="$(git rev-parse --git-path hooks 2>/dev/null)" || { echo "portable-ci: not a git repo" >&2; exit 2; }
  mkdir -p "$dir"
  local path="$dir/$hook"
  if [ -e "$path" ] && ! grep -q "portable-ci managed hook" "$path" 2>/dev/null; then
    echo "portable-ci: $path already exists and is not managed by portable-ci; leaving it alone." >&2
    exit 1
  fi
  cat > "$path" <<'HOOK'
#!/usr/bin/env bash
# portable-ci managed hook — runs local CI before the git action proceeds.
exec ci run
HOOK
  chmod +x "$path"
  echo "portable-ci: installed $hook hook at $path"
}

# ---------- arg parsing ----------
case "${1:-run}" in
  init)          MODE="init"; shift ;;
  doctor)        MODE="doctor"; shift ;;
  install-hook)  shift; install_hook "${1:-pre-push}"; exit 0 ;;
  resolve-repo)  shift; [ "${1:-}" = "--repo" ] && REPO="$2"; resolve_repo; exit 0 ;;
  --version|-V)  echo "portable-ci $VERSION"; exit 0 ;;
  -h|--help)     usage; exit 0 ;;
  run)           shift ;;
esac

while [ $# -gt 0 ]; do
  case "$1" in
    --config)         CONFIG="$2"; shift 2 ;;
    --since)          SINCE="$2"; shift 2 ;;
    --publish-status) PUBLISH_STATUS=1; shift ;;
    --context)        STATUS_CONTEXT="$2"; shift 2 ;;
    --repo)           REPO="$2"; shift 2 ;;
    -h|--help)        usage; exit 0 ;;
    *) echo "portable-ci: unknown argument: $1" >&2; usage; exit 2 ;;
  esac
done

# ---------- main ----------
if [ "$MODE" = "init" ]; then
  init_config
  exit 0
fi

if [ "$MODE" = "doctor" ]; then
  printf '%sportable-ci doctor%s — checking configured tools\n\n' "$C_BOLD" "$C_RESET"
  load_steps
  echo
  if [ "$MISSING" -gt 0 ]; then
    printf '%s%s tool(s) missing.%s\n' "$C_RED" "$MISSING" "$C_RESET"; exit 1
  fi
  printf '%sall configured tools present.%s\n' "$C_GREEN" "$C_RESET"; exit 0
fi

compute_changed_files
load_steps

echo "── portable-ci summary ──"
for r in "${RESULTS[@]:-}"; do
  [ -n "$r" ] || continue
  name="${r#*|}"
  if [ "${r%%|*}" = "ok" ]; then printf '  %s✓%s %s\n' "$C_GREEN" "$C_RESET" "$name"
  else printf '  %s✗%s %s\n' "$C_RED" "$C_RESET" "$name"; fi
done

[ "$PUBLISH_STATUS" -eq 1 ] && publish_status

if [ "$FAIL" -ne 0 ]; then
  printf '%sportable-ci: FAILED%s\n' "$C_RED" "$C_RESET"
else
  printf '%sportable-ci: passed%s\n' "$C_GREEN" "$C_RESET"
fi
exit "$FAIL"
